    "drizzle-orm": "^0.40.0",
    "drizzle-kit": "^0.30.0",
    "postgres": "^3.4.0"
  },
  "devDependencies": {
    "bun-types": "^1.2.0",
    "typescript": "^5.8.0"
  }
}
