# ── Server ──────────────────────────────────────────────
PORT=1234
DATABASE_URL=postgres://postgres:postgres@localhost:5432/skillpass
# Generate a strong secret: `openssl rand -hex 64` (must be ≥ 32 bytes).
# The server refuses to boot with a shorter value, with the empty
# string, or with a known-weak entry from the deny-list in
# internal/config/config.go.
JWT_SECRET=
CORS_ORIGIN=http://localhost:4200
SERVE_STATIC=true

# ── Auth & Security ─────────────────────────────────────
COOKIE_SECURE=false
GIN_MODE=debug

# ── Seed data ───────────────────────────────────────────
# this is for development only
ADMIN_EMAIL=admin@skillpass.com
ADMIN_PASSWORD=pass123!

# ── LLM (AI evaluation, resume parsing, career path) ────
# LLM_PROVIDER: "openai" (default) or "anthropic"
LLM_PROVIDER=
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=https://api.openai.com/v1

# ── Email delivery ──────────────────────────────────────
# Leave SMTP_HOST empty in dev: emails are printed to the
# server console instead (verification/reset links included).
APP_URL=http://localhost:4200
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=no-reply@skillpass.local

# ── File uploads (avatars) ──────────────────────────────
UPLOAD_DIR=./uploads

# ── MarkItDown (PDF → Markdown microservice) ───────────
# Leave empty in dev to fall back to the basic Go PDF extractor.
# In Docker: http://markitdown:8000
MARKITDOWN_URL=
