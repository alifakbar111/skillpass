+		return
+	}
+	c.JSON(http.StatusOK, gin.H{"message": "Updated"})
+}
+
+func (h *Handler) DeleteType(c *gin.Context) {
+	companyID, err := uuid.Parse(c.GetString("companyId"))
+	if err != nil {
+		c.JSON(http.StatusBadRequest, gin.H{"error": "Invalid company ID"})
