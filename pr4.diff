+
+// ── Leave Requests ──
+
+func (h *Handler) CreateRequest(c *gin.Context) {
+	companyID, err := uuid.Parse(c.GetString("companyId"))
+	if err != nil {
+		c.JSON(http.StatusBadRequest, gin.H{"error": "Invalid company ID"})
+		return
+	}
+	employeeID, err := uuid.Parse(c.GetString("employeeId"))
+	if err != nil {
