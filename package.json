{
  "name": "skillpass",
  "private": true,
  "scripts": {
    "dev": "concurrently -n server,web -c cyan,green \"bun --cwd server dev\" \"bun --cwd web dev\"",
    "dev:server": "bun --cwd server dev",
    "dev:web": "bun --cwd web dev",
    "build": "bun --cwd web build",
    "db:push": "bun --cwd server db:push",
    "db:seed": "bun --cwd server seed",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "lint": "biome check .",
    "lint:fix": "biome check --write --unsafe .",
    "format": "biome format --write .",
    "format:check": "biome format ."
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "@biomejs/biome": "^2.4.15"
  }
}
