# ── SkillPass Dev Server Environment ─────────────────────
# Copy this to .env and fill in your values.
# cp .env.prod.example .env

# ── VPS connection (for deploy.sh) ──
VPS_HOST=root@<YOUR_VPS_IP>
DOCKER_USER=your-dockerhub-username

# ── Database (REQUIRED: change passwords before deploying) ──
DB_PASSWORD=<change-this-to-a-strong-random-secret>
ADMIN_PASSWORD=<change-this-too>

# ── Server (DATABASE_URL is auto-set by docker-compose to point at local db) ──
PORT=1234
JWT_SECRET=<change-this-to-a-strong-random-secret>
CORS_ORIGIN=http://<YOUR_VPS_IP>
APP_URL=http://<YOUR_VPS_IP>
SERVE_STATIC=true
GIN_MODE=release
COOKIE_SECURE=false

# ── LLM (AI evaluation, resume parsing, career path) ────
LLM_PROVIDER=openai
LLM_API_KEY=sk-xxxxxxxxxxxxxxxx
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=https://api.openai.com/v1

# ── Email delivery ──────────────────────────────────────
# Leave SMTP_HOST empty: emails print to server console
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=no-reply@skillpass.local

# ── Admin seed account ──────────────────────────────────
ADMIN_EMAIL=admin@skillpass.com

# ── File uploads (avatars, resumes) ─────────────────────
UPLOAD_DIR=./uploads

# ── MarkItDown ──────────────────────────────────────────
MARKITDOWN_URL=http://markitdown:8000
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
